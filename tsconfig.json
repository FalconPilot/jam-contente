{
  "compilerOptions": {
    "target": "ES2022",
    "types": ["vite/client"],
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "jsx": "react-jsx",
    "noUncheckedIndexedAccess": true
  },
  "exclude": [
    "node_modules"
  ],
  "include": [
    "src"
  ]
}
